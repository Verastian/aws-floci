# Copia este archivo a ".env" (en esta misma carpeta) y completa tus valores reales.
# ".env" está en .gitignore -- nunca se sube al repositorio.
#
# Usado por plataforma/scripts/floci-tunnel.sh (el túnel SSH persistente hacia Floci)
# y, en general, por cualquier script de este repo que necesite la IP del VPS.

# IP o hostname público del VPS donde corre Floci.
FLOCI_VPS_HOST=<TU-IP-VPS>

# Usuario SSH usado para el túnel (el mismo que en la guía: acceso root directo).
FLOCI_VPS_USER=root

# Puerto local (en tu equipo) donde queda expuesto el endpoint de Floci.
FLOCI_LOCAL_PORT=4566

# Puerto remoto (en el VPS) donde escucha Floci. Normalmente igual al local.
FLOCI_REMOTE_PORT=4566

# Dominio publico (real) usado para exponer Floci de forma acotada via
# nginx-proxy-manager. Ver proyectos/quiz/docs/GUIA-SERVICIOS-AVANZADOS.md
# seccion 1 y plataforma/scripts/npm-configure-floci-host.py.
FLOCI_PUBLIC_DOMAIN=<TU-SUBDOMINIO>

# Puerto publicado en el host para la UI/API de nginx-proxy-manager (el puerto
# interno del contenedor es 81, pero Docker lo publica en uno aleatorio --
# confirmar con `docker port <contenedor-npm>`, puede cambiar si se recrea).
NPM_API_PORT=<PUERTO-ADMIN-NPM>

# Nombre del contenedor de Floci en el VPS (para que nginx-proxy-manager lo
# alcance por nombre en la red Docker floci_default).
FLOCI_CONTAINER_NAME=floci-floci-1
