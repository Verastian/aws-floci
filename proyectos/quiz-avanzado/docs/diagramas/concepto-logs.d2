direction: right

codigo: "Tu código\n(console.log/console.error\ndentro de la Lambda)" {
  style.fill: "#dbeafe"
}
grupo: "Log Group\n(un cuaderno por función,\nej. /aws/lambda/quiz-submit)" {
  style.fill: "#fef3c7"
}
stream: "Log Stream\n(una página del cuaderno,\nuna por tanda de ejecuciones)" {
  style.fill: "#fde68a"
}
evento: "Log Event\n(una línea: fecha,\nid de invocación, mensaje)" {
  style.fill: "#fed7aa"
}
vos: "Vos / tu equipo\n(consola AWS o\n`aws logs tail`)" {
  style.fill: "#ede9fe"
}

codigo -> grupo: "1. se escribe"
grupo -> stream: "2. se agrupa"
stream -> evento: "3. se guarda"
evento -> vos: "4. lo consultás" {
  style.stroke-dash: 4
}
